<launch>

  <!-- ============================= -->
  <!-- Arguments -->
  <!-- ============================= -->
  <arg name="use_servo" default="true"/>

  <!-- Shared Config File -->
  <let name="config_file"
       value="$(find-pkg-share robot_patrol)/config/robot_config.yaml"/>

  <!-- ============================= -->
  <!-- Minimec Bringup -->
  <!-- ============================= -->
  <include
    file="$(find-pkg-share minimec_bringup)/launch/launch_minimec.launch.py">
    <arg name="cmd_src" value="teleop"/>
  </include>

  <!-- ============================= -->
  <!-- Ball Chaser -->
  <!-- ============================= -->
  <node
    pkg="robot_patrol"
    exec="ball_chaser"
    name="ball_chaser"
    output="screen">

    <param from="$(var config_file)"/>
  </node>

  <!-- ============================= -->
  <!-- Optional Servo Control -->
  <!-- ============================= -->
  <node
    pkg="robot_patrol"
    exec="servo_control"
    name="servo_control"
    output="screen"
    if="$(var use_servo)">

    <param from="$(var config_file)"/>
  </node>

</launch>