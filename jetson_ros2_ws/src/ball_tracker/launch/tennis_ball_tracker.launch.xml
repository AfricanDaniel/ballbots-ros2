<launch>

  <!-- ============================= -->
  <!-- Arguments -->
  <!-- ============================= -->
  <arg
    name="use_yolo"
    default="true"
    description="true=YOLO tracker (default), false=HSV tracker"
  />

  <arg
    name="use_zed"
    default="false"
    description="true=also launch ZED tracker alongside RealSense"
  />

  <arg
    name="use_rviz"
    default="false"
    description="Launch RViz visualization"
  />

  <arg
    name="debug_logs"
    default="false"
    description="Enable verbose detection logs"
  />

  <!-- ============================= -->
  <!-- RealSense Camera Launch -->
  <!-- Align depth to colour — required by both trackers -->
  <!-- ============================= -->
  <include
    file="$(find-pkg-share realsense2_camera)/launch/rs_launch.py">
    <arg name="align_depth.enable" value="true"/>
  </include>

  <!-- ============================= -->
  <!-- ZED Camera Launch -->
  <!-- Kept for odometry (/zed/zed_node/odom) -->
  <!-- ============================= -->
  <include
    file="$(find-pkg-share zed_wrapper)/launch/zed_camera.launch.py">
    <arg name="camera_model" value="zed2i"/>
    <arg name="camera_name"  value="zed"/>
  </include>

  <!-- ============================= -->
  <!-- YOLO Tracker (default)        -->
  <!-- Replaces all three HSV nodes: -->
  <!--   tennis_ball_tracker.py      -->
  <!--   realsense_tracker.py        -->
  <!--   bottle_tracker.py           -->
  <!--                               -->
  <!-- Launch with YOLO (default):   -->
  <!--   ros2 launch ball_tracker    -->
  <!--     tennis_ball_tracker.launch.xml -->
  <!-- ============================= -->
  <node
    pkg="ball_tracker"
    exec="realsense_tracker_yolo"
    name="realsense_tracker_yolo"
    output="screen"
    if="$(var use_yolo)"
  >
    <param name="debug_logs" value="$(var debug_logs)"/>
  </node>

  <!-- ============================= -->
  <!-- HSV Tracker (fallback)        -->
  <!-- RealSense handles ball +      -->
  <!-- bottle + pole via HSV masks   -->
  <!--                               -->
  <!-- Launch with HSV:              -->
  <!--   ros2 launch ball_tracker    -->
  <!--     tennis_ball_tracker.launch.xml use_yolo:=false -->
  <!-- ============================= -->
  <node
    pkg="ball_tracker"
    exec="realsense_tracker"
    name="realsense_tracker"
    output="screen"
    unless="$(var use_yolo)"
  >
    <param name="debug_logs" value="$(var debug_logs)"/>
    <remap from="/tennis_ball_position_close" to="/tennis_ball_position"/>
  </node>

  <!-- ============================= -->
  <!-- ZED Tracker (optional)        -->
  <!-- Runs alongside RealSense when -->
  <!-- use_zed:=true                 -->
  <!-- ============================= -->
  <group if="$(var use_zed)">
    <node
      pkg="ball_tracker"
      exec="zed_tracker_yolo"
      name="zed_tracker_yolo"
      output="screen"
      if="$(var use_yolo)"
    >
      <param name="debug_logs" value="$(var debug_logs)"/>
    </node>

    <node
      pkg="ball_tracker"
      exec="zed_tracker"
      name="zed_tracker"
      output="screen"
      unless="$(var use_yolo)"
    >
      <param name="debug_logs" value="$(var debug_logs)"/>
    </node>
  </group>

  <!-- ============================= -->
  <!-- RViz (optional) -->
  <!-- ============================= -->
  <node
    pkg="rviz2"
    exec="rviz2"
    name="rviz2"
    output="screen"
    if="$(var use_rviz)"
    args="-d $(find-pkg-share ball_tracker)/config/tennis_visualization.rviz"
  />

</launch>